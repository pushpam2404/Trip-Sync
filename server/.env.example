# ─── TripSync Server Environment Variables ───
# Copy this file to .env and fill in the values

# Server port (default: 3001)
PORT=3001

# MongoDB connection string
# Local: mongodb://localhost:27017/tripsync
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/tripsync
MONGO_URI=mongodb://localhost:27017/tripsync

# JWT signing secret — generate a secure random string
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Node environment
NODE_ENV=development

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
